# Free Groq key: https://console.groq.com/keys  (starts with gsk_)
GROQ_API_KEY=

GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.1-70b-versatile
OPENAI_VISION_MODEL=llama-3.2-11b-vision-preview

# You can use OPENAI_API_KEY instead of GROQ_API_KEY if you prefer

# Demo mode — no API key needed (sample questions)
USE_MOCK_AI=true

# USE_MOCK_AI=true forces placeholder questions when no API key is set
