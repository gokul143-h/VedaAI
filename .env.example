# --- Meta Llama API (recommended) ---
# Get a free key: https://llama.developer.meta.com/
AI_PROVIDER=meta
LLAMA_API_KEY=
# LLAMA_BASE_URL=https://api.llama.com/compat/v1
OPENAI_MODEL=Llama-3.3-70B-Instruct
OPENAI_VISION_MODEL=Llama-4-Scout-17B-16E-Instruct-FP8

# --- Open WebUI (local models) ---
# AI_PROVIDER=openwebui
# OPENWEBUI_BASE_URL=http://localhost:8080/api
# OPENWEBUI_API_KEY=
# OPENAI_MODEL=GPT-5.5
# OPENAI_VISION_MODEL=GPT-5.5

# --- Groq (cloud alternative) ---
# AI_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-70b-versatile
# OPENAI_VISION_MODEL=llama-3.2-11b-vision-preview

# Demo mode — sample questions without an API key
USE_MOCK_AI=true

# Local dev — Express API on port 4000
NEXT_PUBLIC_API_PORT=4000

# Vercel production (https://vedaai-omega.vercel.app)
# Do NOT set NEXT_PUBLIC_API_URL=http://localhost:4000 on Vercel.
# For built-in generation on Vercel, set:
# GROQ_API_KEY=...
# USE_MOCK_AI=false
# For Render backend, set:
# BACKEND_API_URL=https://YOUR-SERVICE.onrender.com
# NEXT_PUBLIC_API_URL=https://YOUR-SERVICE.onrender.com
# NEXT_PUBLIC_WS_URL=wss://YOUR-SERVICE.onrender.com/ws
