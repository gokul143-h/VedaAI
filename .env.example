# =============================================================================
# Vercel production (https://vedaai-omega.vercel.app) — recommended
# =============================================================================
# Free Llama via Groq: https://console.groq.com/keys
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_VISION_MODEL=llama-3.2-11b-vision-preview
USE_MOCK_AI=false

# =============================================================================
# Meta Llama API (alternative) — https://llama.developer.meta.com/
# =============================================================================
# AI_PROVIDER=meta
# LLAMA_API_KEY=
# LLAMA_BASE_URL=https://api.llama.com/compat/v1
# OPENAI_MODEL=Llama-3.3-70B-Instruct
# OPENAI_VISION_MODEL=Llama-4-Scout-17B-16E-Instruct-FP8

# =============================================================================
# Open WebUI (local dev only)
# =============================================================================
# AI_PROVIDER=openwebui
# OPENWEBUI_BASE_URL=http://localhost:8080/api
# OPENWEBUI_API_KEY=

# Local Express API (dev)
NEXT_PUBLIC_API_PORT=4000

# Optional Render backend
# BACKEND_API_URL=https://vedaai-api.onrender.com
# NEXT_PUBLIC_API_URL=https://vedaai-api.onrender.com
# NEXT_PUBLIC_WS_URL=wss://vedaai-api.onrender.com/ws
